<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{ title || 'Vite & Gourmand' }}</title>
    <style>
      body {
        margin: 0;
        background-color: #faf7f2;
        font-family:
          'DM Sans',
          -apple-system,
          BlinkMacSystemFont,
          'Segoe UI',
          Roboto,
          Helvetica,
          Arial,
          sans-serif;
        color: #1a1a1a;
      }
      .title {
        font-family: Georgia, 'Times New Roman', serif;
        font-size: 24px;
        font-weight: 700;
        margin-top: 0;
        margin-bottom: 16px;
        color: #1a1a1a;
      }
      .text {
        font-size: 15px;
        line-height: 24px;
        color: #1a1a1a;
        margin-bottom: 20px;
      }
      .button {
        display: inline-block;
        background-color: #5c1f2e;
        color: #faf7f2 !important;
        padding: 12px 24px;
        text-decoration: none !important;
        border-radius: 6px;
        font-weight: 500;
        font-size: 14px;
      }
      .info-box {
        background-color: #fbf3f4;
        border-left: 4px solid #c9a55a;
        padding: 12px 16px;
        font-size: 13px;
        color: #6b6460;
        margin-bottom: 24px;
      }
      .field-label {
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: #6b6460;
        margin-bottom: 4px;
      }
    </style>
  </head>
  <body>
    <table
      role="presentation"
      border="0"
      cellpadding="0"
      cellspacing="0"
      width="100%"
      style="background-color: #faf7f2; padding: 24px 0;"
    >
      <tr>
        <td>
          <table
            role="presentation"
            border="0"
            cellpadding="0"
            cellspacing="0"
            width="100%"
            style="max-width: 560px; margin: 0 auto;"
          >
            <tr>
              <td
                style="text-align: center; padding-bottom: 24px; font-family: Georgia, 'Times New Roman', serif; font-size: 22px; font-weight: 700; color: #5c1f2e;"
              >
                Vite &amp; Gourmand
              </td>
            </tr>
            <tr>
              <td
                style="background: #ffffff; border: 1px solid #ddd8d1; border-radius: 8px; padding: 32px;"
              >
                {{{ await $slots.main() }}}
              </td>
            </tr>
            <tr>
              <td
                style="text-align: center; padding-top: 32px; font-size: 12px; color: #6b6460; line-height: 18px;"
              >
                Cet e-mail a été envoyé automatiquement par Vite &amp; Gourmand.
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
